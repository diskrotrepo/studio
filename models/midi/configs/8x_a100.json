    "dropout": 0.2,
    "warmup_pct": 0.15,
    "epochs": 8,
    "val_split": 0.1,
    "early_stopping_patience": 3,
    "grad_clip_norm": 1.0,
    "use_tags": true,
    "use_compile": true,
    "distributed_timeout_minutes": 60
}
